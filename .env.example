# URL del backend NestJS
# Dev: http://localhost:3000
# Prod: https://tu-backend.railway.app (o la URL de tu hosting)
VITE_API_URL=http://localhost:3000

# Entorno: development | production
VITE_APP_ENV=development

# 2FA — true en producción, false para desarrollo sin 2FA
VITE_ENABLE_2FA=false

# Dummy 2FA code para dev (ignorado si VITE_ENABLE_2FA=true)
VITE_2FA_DUMMY_CODE=000000
